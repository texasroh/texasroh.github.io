# Firebase web config for the post view counter.
# These values are NOT secret — they ship in the client bundle and access is
# governed by Firestore security rules (see firestore.rules). Copy this file to
# .env.local and fill in the values from the Firebase console:
#   Project settings -> General -> Your apps -> SDK setup and configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional — only for Analytics (GA4). Enable Google Analytics on the project,
# then copy the measurement id (G-XXXXXXX). Leave blank to keep Analytics off.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
